rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net (default-deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    // Check if user is a bootstrapped admin or has role 'admin' in users collection
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'alawyabbas15@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ); 
    }

    // Check if user has role 'editor' or higher
    function isEditor() {
      return isSignedIn() && (
        request.auth.token.email == 'alawyabbas15@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor'
      );
    }

    // Entity validations
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role', 'joinDate', 'status'])
        && data.keys().size() <= 8
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 200
        && data.role in ['admin', 'editor', 'user']
        && data.joinDate is string && data.joinDate.size() <= 100
        && data.status in ['active', 'suspended'];
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['id', 'title', 'shortDescription', 'content', 'category', 'coverImage', 'author', 'publishDate', 'views'])
        && data.keys().size() <= 15
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.shortDescription is string && data.shortDescription.size() <= 500
        && data.content is string && data.content.size() <= 20000
        && data.category is string && data.category.size() <= 50
        && data.coverImage is string && data.coverImage.size() <= 1000
        && data.author is string && data.author.size() <= 100
        && data.publishDate is string && data.publishDate.size() <= 100
        && data.views is int;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['id', 'articleId', 'authorName', 'content', 'date'])
        && data.keys().size() <= 7
        && data.id is string && data.id.size() <= 128
        && data.articleId is string && data.articleId.size() <= 128
        && data.authorName is string && data.authorName.size() <= 100
        && data.content is string && data.content.size() <= 2000
        && data.date is string && data.date.size() <= 100;
    }

    function isValidContact(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'message'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 200
        && data.subject is string && data.subject.size() <= 200
        && data.message is string && data.message.size() <= 5000;
    }

    // Rules for "users" collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && userId == request.auth.uid 
        && isValidUser(incoming())
        // Standard user cannot self-assign admin/editor roles unless they are bootstrapped
        && (incoming().role == 'user' || request.auth.token.email == 'alawyabbas15@gmail.com');
      
      allow update: if isSignedIn() 
        && userId == request.auth.uid 
        && isValidUser(incoming())
        // Do not allow self-modifying roles or statuses unless admin
        && (
          (incoming().role == existing().role && incoming().status == existing().status) ||
          isAdmin()
        );
      
      allow delete: if isAdmin();
    }

    // Rules for "articles" collection
    match /articles/{articleId} {
      allow read: if true;
      allow create: if isEditor() && isValidArticle(incoming()) && isValidId(articleId);
      
      // Allow editors to update any article fields, or allows anyone to increment views only
      allow update: if (
        (isEditor() && isValidArticle(incoming())) ||
        (isValidArticle(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['views']))
      );
      
      allow delete: if isEditor();

      // Rules for comments nested subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidComment(incoming()) && isValidId(commentId);
        allow update: if isSignedIn() && (
          // Comment author can edit their comment content only
          (existing().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content'])) ||
          isAdmin()
        );
        allow delete: if isSignedIn() && (
          existing().authorId == request.auth.uid ||
          isEditor()
        );
      }
    }

    // Rules for "contacts" collection
    match /contacts/{contactId} {
      allow create: if isValidContact(incoming()) && isValidId(contactId);
      allow read, update, delete: if isEditor();
    }
  }
}
