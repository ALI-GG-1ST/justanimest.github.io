{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and profile details",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique user ID"
        },
        "name": {
          "type": "string",
          "description": "The user's display name",
          "maxLength": 100
        },
        "email": {
          "type": "string",
          "description": "The user's email address",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "editor", "user"],
          "description": "The user's system role"
        },
        "joinDate": {
          "type": "string",
          "description": "ISO date string of when user joined"
        },
        "status": {
          "type": "string",
          "enum": ["active", "suspended"],
          "description": "Account status"
        },
        "avatarUrl": {
          "type": "string",
          "description": "Profile picture URL"
        },
        "isGoogleUser": {
          "type": "boolean",
          "description": "Signed in with Google"
        }
      },
      "required": ["id", "name", "email", "role", "joinDate", "status"]
    },
    "Article": {
      "title": "Anime Article",
      "description": "An article or blog post about anime/manga",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Article unique identifier"
        },
        "title": {
          "type": "string",
          "description": "Title of the article",
          "maxLength": 200
        },
        "shortDescription": {
          "type": "string",
          "description": "Short description / summary",
          "maxLength": 500
        },
        "content": {
          "type": "string",
          "description": "Rich content of the article",
          "maxLength": 20000
        },
        "category": {
          "type": "string",
          "description": "Article category (e.g. news, reviews)",
          "maxLength": 50
        },
        "coverImage": {
          "type": "string",
          "description": "Cover image URL"
        },
        "tags": {
          "type": "array",
          "description": "List of tags associated"
        },
        "author": {
          "type": "string",
          "description": "Author of the article"
        },
        "publishDate": {
          "type": "string",
          "description": "ISO date of publication"
        },
        "readTime": {
          "type": "string",
          "description": "Estimated read time"
        },
        "keywords": {
          "type": "array",
          "description": "SEO keywords"
        },
        "isFeatured": {
          "type": "boolean"
        },
        "isTrending": {
          "type": "boolean"
        },
        "views": {
          "type": "number"
        },
        "lang": {
          "type": "string",
          "enum": ["ar", "en"]
        }
      },
      "required": ["id", "title", "shortDescription", "content", "category", "coverImage", "author", "publishDate", "views"]
    },
    "Comment": {
      "title": "Article Comment",
      "description": "User comments on articles",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "articleId": {
          "type": "string"
        },
        "authorName": {
          "type": "string",
          "maxLength": 100
        },
        "authorId": {
          "type": "string"
        },
        "content": {
          "type": "string",
          "maxLength": 2000
        },
        "date": {
          "type": "string"
        }
      },
      "required": ["id", "articleId", "authorName", "content", "date"]
    },
    "ContactMessage": {
      "title": "Contact Form Submission",
      "description": "Messages sent from contact us page",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 100
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "subject": {
          "type": "string",
          "maxLength": 200
        },
        "message": {
          "type": "string",
          "maxLength": 5000
        }
      },
      "required": ["name", "email", "subject", "message"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profile details"
    },
    "articles/{articleId}": {
      "schema": "Article",
      "description": "Collection of anime/manga articles"
    },
    "articles/{articleId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Subcollection of comments belonging to a specific article"
    },
    "contacts/{contactId}": {
      "schema": "ContactMessage",
      "description": "Collection of contact us message submissions"
    }
  }
}
